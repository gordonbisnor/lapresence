<div class="item <%= cycle("even","odd") %>" id="sort_item_<%= atelier.id %>">
	<div class="actions">
		<%= link_to "Edit", edit_admin_atelier_path(atelier) %> <%= link_to "Delete", admin_atelier_path(atelier), method: :delete, data: {confirm: "Are you sure?"} %>
	</div>
	<%= link_to atelier.title, atelier, target: "_blank" %> 
</div>