= stylesheet_pack_tag "admin_attachments"

- if @item.persisted?
  %h2 Attachment ##{@item.id}
= simple_form_for([:admin, @item]) do |f|
  
  .flex.w-100.justify-stretch

    %div.pr5{style: "flex-grow: 1"}
      = f.input :name
      = f.file_field :attachment 
      = render "admin/shared/save_cancel", text: "Attachment"

    -  if @item.shrine
      %div.pl5{style: "flex-grow: 1"}
        .f2.green= content_typer @item.content_type
        %h2 Metadata 
        %dl
          - @item.shrine.metadata.each_pair do |k,v|
            %dt.blue= k.titlecase
            %dd= k == 'size' ? number_to_human_size(v) : v
          %dt.blue Analyzed MIME type
          %dd= @item.shrine.mime_type

    .upload-preview.pl3
      - if @item.shrine_url && @item.image?
        = image_tag @item.shrine_url, style: "max-width:280px;"
      - elsif @item.image?
        .upload-preview= image_tag @item.attachment.url
      - elsif @item.shrine_url && @item.shrine.mime_type == "audio/mpeg"
        %audio{controls: true}
          %source{src: @item.shrine_url, type: "audio/mpeg"}
          Your browser does not support the audio tag.
      - elsif @item.shrine_url && @item.shrine.mime_type == "video/mp4"
        %video{width: "320", height: "240", controls: true}
          %source{src: @item.shrine_url, type: "video/mp4"}
          Your browser does not support the video tag.



= javascript_pack_tag "admin_attachments"