<%= title "Edit Page" , :h1 %>
<%= render :partial => "admin/pages/form" %>

<div id="versions">
	<h2>Previous Versions</h2>
	<div class="content">
		<p>click to view, press “Update Page” to revert permanently to that version</p>
		<ul>
			<% @versions.each do |version| -%>
				<li><%= link_to "Version #{version.number} - #{version.created_at.to_s(:long_ordinal)}", edit_admin_page_path(:version=>version.number) %></li>
				<% end -%>
			</ul>
	</div>
</div>
