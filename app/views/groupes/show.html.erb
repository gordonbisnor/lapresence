<h1><%= link_to @groupe.title, @groupe %></h1>

<%= image_tag @groupe.picture.url(:thumb), :class => "float_right" %>

<%= raw @groupe.content %>

<dl>
	<% if dates(@groupe).present? -%>
		<dt>Dates</dt> <dd><%= dates(@groupe) %></dd>
	<% end %>
	<% if @groupe.schedule.present? -%>
		<dt>Horaire</dt> <dd><%= @groupe.schedule %></dd>
	<% end -%>
	<% if @groupe.location.present? -%>
	<dt>Lieu</dt> <dd><%= @groupe.location %></dd>
	<% end -%>
	<% if @groupe.cost.present? -%>
	<dt>Coût</dt> <dd><%= @groupe.cost %></dd>
	<% end -%>
	<% if @groupe.available_spots.present? -%>
	<dt>Places limitées</dt> <dd><%= @groupe.available_spots %></dd>
	<% end -%>
	<% if @groupe.notes.present? -%>
	<dt>Notes complémentaires</dt> <dd><%= @groupe.notes %></dd>
	<% end %>
</dl>