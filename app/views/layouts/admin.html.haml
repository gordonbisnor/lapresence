!!! 5
%html(lang="en")
  %head
    %meta(charset="utf-8")
    %meta(http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1")
    %title= content_for?(:title) ? yield(:title) : "Lapresence"
    = viewport_meta_tag
    = csrf_meta_tags
    = stylesheet_link_tag "admin", :media => "all"
    = stylesheet_link_tag '//ajax.googleapis.com/ajax/libs/jqueryui/1.11.1/themes/cupertino/jquery-ui.css'
    = stylesheet_link_tag "//maxcdn.bootstrapcdn.com/bootstrap/3.3.4/css/bootstrap.min.css"
    
    = javascript_include_tag "https://cdn.tiny.cloud/1/y3gjkojvgk51wmonr2nk5a7eaxk8tc06f52szhkaw87wury5/tinymce/5/tinymce.min.js"
    
    = javascript_include_tag :admin
    = javascript_include_tag "//maxcdn.bootstrapcdn.com/bootstrap/3.3.4/js/bootstrap.min.js"
    
  %body
    =render "layouts/admin_nav"
    .container
      = bootstrap_flash
      = yield

    = yield :js
