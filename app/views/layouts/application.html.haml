!!!
%html{lang: "en"}
  %head
    %title= @page_title || APP_CONFIG[:site_name]
    %meta{:content => "text/xhtml; charset=utf-8", "http-equiv" => "content-type"}
    %meta{:content => "no", "http-equiv" => "imagetoolbar"}
    %meta{:content => "all", :name => "distribution"}
    %meta{:content => "all", :name => "robots"}
    %meta{:content => "document", :name => "resource-type"}
    %meta{:content => "true", :name => "MSSmartTagsPreventParsing"}
    %meta{:content => @seo_description, :name => "Description"}
    %meta{name:"viewport", content: "width=device-width, initial-scale=1"}
    %meta{content: "fr_CA", property: "og:locale"}
    %meta{content: APP_CONFIG[:site_name], property: "og:site_name"}
    %meta{content: @seo_title, property: "og:title"}
    %meta{content: @seo_url, property: "og:url"}
    %meta{content: "website", property: "og:type"}
    %meta{content: @seo_description, property: "og:description"}
    %meta{content: @seo_image, property: "og:image"}
    %meta{content: @seo_image, property: "og:image:url"}
    %meta{content: @seo_image, property: "og:image:secure_url"}
    %meta{content: @seo_title, itemprop: "name"}
    %meta{content: @seo_headline, itemprop: "headline"}
    %meta{content: @seo_description, itemprop: "description"}
    %meta{content: @seo_image, itemprop: "image"}
    %meta{content: @seo_title, name: "twitter:title"}
    %meta{content: @seo_url, name: "twitter:url"}
    %meta{content: @seo_description, name: "twitter:description"}
    %meta{content: @seo_image, name: "twitter:image"}
    %meta{content: "summary_large_image", name: "twitter:card"}
    = stylesheet_link_tag "application", :media => "all"
    = csrf_meta_tags
    = render partial: "layouts/analytics"
  %body
    #container
      %header#header
        = image_tag "banner.jpg", :alt => "La Présence", id: "banner"
        %nav#navigation_container
          %ul#navigation
            = raw navigation
      %main#content
        = raw flash_messages
        = yield :layout
      %footer#footer
        %ul#footer_navigation= raw navigation
        .container
          .pull-left= link_to "Inscrivez-vous à ma liste d’envoi", "http://eepurl.com/bf-L71", class: 'btn btn-primary'
          %a{href: "mailto:pratiquer@lapresence.ca"} Pratiquer@LaPresence.ca
    %footer#post_footer
      #credit
        designer web :
        %a{href: "mailto:arti@endirect.qc.ca"} Johanne Ratté 2008
        |
        = succeed ":" do
          %a{href: "https://www.isnorcreative.com"} Ruby on Rails Development
        Isnor Creative
      %a{href: "/admin"} Admin
