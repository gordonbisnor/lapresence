<script>
  ClassicEditor
    .create(document.querySelector('#<%= id %>'), {
      toolbar: {
        items: [
          'heading',
          '|',
          'bold',
          'italic',
          'link',
          'underline',
          'strikethrough',
          'bulletedList',
          'numberedList',
          'alignment',
          '|',
          'indent',
          'outdent',
          '|',
          'imageUpload',
          'blockQuote',
          'insertTable',
          'mediaEmbed',
          'undo',
          'redo',
          'fontBackgroundColor',
          'fontColor',
          'fontSize',
          'fontFamily',
          'highlight',
          'horizontalLine',
          'removeFormat',
          'source'
        ]
      },

      fontSize: {
        options: [
          9,
          10,
          11,
          12,
          14,
          'default',
          16,
          18,
          20,
          24,
          32,
          36,
          40,
          48,
          60,
          72,
          96,
        ]
      },

      simpleUpload: {
